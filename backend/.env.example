# LLM Config
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini # openai, gemini, ollama, mock
LLM_MODEL=gemini-2.0-flash # gpt-4-turbo, gemini-2.0-flash, llama3.1, etc.
OLLAMA_BASE_URL=http://localhost:11434 # connection URL to local Ollama server

# Specific Agent Groups Routing
LLM_PROVIDER_HEAVY=gemini
LLM_MODEL_HEAVY=gemini-2.0-flash
LLM_PROVIDER_LIGHT=ollama
LLM_MODEL_LIGHT=llama3.1

# Database Config
DB_HOST=db
DB_PORT=5432
DB_NAME=falcon_copilot
DB_USER=copilot
DB_PASSWORD=copilot_secure_pass

# CrowdStrike API Config (READ-ONLY Scopes)
FALCON_CLIENT_ID=your_falcon_client_id
FALCON_CLIENT_SECRET=your_falcon_client_secret
FALCON_BASE_URL=https://api.crowdstrike.com # or https://api.us-2.crowdstrike.com etc.

# Application Server
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
